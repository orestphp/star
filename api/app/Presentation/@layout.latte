<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width">

	<title>{ifset title}{include title|stripHtml} | {/ifset}Nette Web</title>

	<link rel="stylesheet" href="{$basePath}/css/style.css">

	<script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
	{asset? 'main.js'}
	<style>

	</style>
</head>

<body>
<div n:foreach="$flashes as $flash" n:class="flash, $flash->type">{$flash->message}</div>

<div class="dashboard-header" style="padding: 1.5rem; background: #fff; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #e5e7eb;">
	<div style="display: flex; align-items: center; gap: 1.5rem;">
		<h1 style="margin: 0; font-family: 'Inter', sans-serif;">Customers</h1>

		<div class="search-wrapper" id="live-search-container" style="display: none;">
			<i class="fa-solid fa-magnifying-glass search-icon"></i>
			<input type="text" id="customer-search" class="search-input" placeholder="Search customers by name or email...">
		</div>
	</div>

	<a href="{link Sign:out}" class="btn-logout">
		<i class="fa-solid fa-right-from-bracket"></i> Sign Out
	</a>
</div>

{include content}

<script src="{$basePath}/js/navigation.js"></script>
<script src="{$basePath}/js/search.js"></script>
<script src="{$basePath}/js/activity-comments.js"></script>

</body>
</html>