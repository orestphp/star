<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width">

	<title>{ifset title}{include title|stripHtml} | {/ifset}Nette Web</title>

	<script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>

	{asset? 'main.js'}
	<style>
		.nav-link {
			text-decoration: none;
			color: #6b7280;
			font-size: 0.95rem;
			font-weight: 500;
			padding-bottom: 0.25rem;
			border-bottom: 2px solid transparent;
			transition: all 0.15s ease-in-out;
		}
		.nav-link.active {
			color: #2563eb;
			font-weight: 600;
			border-bottom: 2px solid #2563eb;
		}
	</style>
</head>

<body>
<div n:foreach="$flashes as $flash" n:class="flash, $flash->type">{$flash->message}</div>

<div class="dashboard-header" style="padding: 1.5rem; background: #fff; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #e5e7eb;">
	<div style="display: flex; align-items: center; gap: 1.5rem;">
		<h1 style="margin: 0; font-family: 'Inter', sans-serif;">Star Dashboard</h1>

		<nav id="dashboard-nav" style="display: flex; gap: 1rem;">
			<a href="{link Customers:default}" class="nav-link">Customers</a>
			<a href="{link Activities:default}" class="nav-link">Activities</a>
		</nav>
	</div>

	<a href="{link Sign:out}" class="btn-logout">
		<i class="fa-solid fa-right-from-bracket"></i> Sign Out
	</a>
</div>

{include content}

<style>
	.btn-logout {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		background-color: #ef4444;
		color: #ffffff;
		padding: 0.5rem 1rem;
		border-radius: 6px;
		text-decoration: none;
		font-family: 'Inter', sans-serif;
		font-size: 0.875rem;
		font-weight: 500;
		transition: background-color 0.15s ease-in-out;
	}
	.btn-logout:hover {
		background-color: #dc2626;
	}
</style>

<script>
	$(document).ready(function() {
		//  Active nav link
		var currentPath = window.location.pathname.toLowerCase();
		if (currentPath === '/' || currentPath === '/index.php') {
			$('#dashboard-nav .nav-link').removeClass('active');
			return;
		}
		$('#dashboard-nav .nav-link').each(function() {
			var linkHref = $(this).attr('href').toLowerCase();
			if (currentPath === linkHref || (linkHref !== '/' && currentPath.indexOf(linkHref) !== -1)) {
				$(this).addClass('active');
			} else {
				$(this).removeClass('active');
			}
		});
	});
</script>
</body>
</html>